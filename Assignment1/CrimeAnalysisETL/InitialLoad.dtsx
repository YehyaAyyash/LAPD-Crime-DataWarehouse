          SQLTask:SqlStatementSource="-- Only truncate accum staging, NOT CrimeIncidents (loaded via Python)&#xA;DELETE FROM STG_AccumulatingUpdate;&#xA;&#xA;-- Clear fact first (FK dependency)&#xA;DELETE FROM FACT_CRIME_INCIDENT;&#xA;&#xA;-- Clear dimensions&#xA;DELETE FROM DIM_VICTIM;&#xA;DELETE FROM DIM_CRIME;&#xA;DELETE FROM DIM_PREMISE;&#xA;DELETE FROM DIM_WEAPON;&#xA;DELETE FROM DIM_AREA;&#xA;DELETE FROM DIM_STATUS;&#xA;&#xA;-- Reset identity counters&#xA;DBCC CHECKIDENT ('DIM_VICTIM',  RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_CRIME',   RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_PREMISE', RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_WEAPON',  RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_AREA',    RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_STATUS',  RESEED, 0);&#xA;DBCC CHECKIDENT ('FACT_CRIME_INCIDENT', RESEED, 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
