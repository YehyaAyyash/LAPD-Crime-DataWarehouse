  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Load DIM Lookup Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{8F74CC9B-D7C6-46E6-9DC4-FBBF0C96EF24}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DIM Lookup Tables"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C4C06672-7538-4198-9C52-3251DFA1BC2C}"
          SQLTask:SqlStatementSource="-- Truncate lookup staging&#xA;DELETE FROM STG_CrimeCode;&#xA;DELETE FROM STG_PremiseCode;&#xA;DELETE FROM STG_WeaponCode;&#xA;DELETE FROM STG_AreaCode;&#xA;DELETE FROM DIM_CRIME;&#xA;DELETE FROM DIM_PREMISE;&#xA;DELETE FROM DIM_WEAPON;&#xA;DELETE FROM DIM_AREA;&#xA;&#xA;DBCC CHECKIDENT ('DIM_CRIME', RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_PREMISE', RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_WEAPON', RESEED, 0);&#xA;DBCC CHECKIDENT ('DIM_AREA', RESEED, 0);&#xA;&#xA;-- Bulk load staging&#xA;BULK INSERT STG_CrimeCode&#xA;FROM 'C:\Users\Yahya\Desktop\SLIIT\Year 3\Sem 2\DWBI\Assignment 1 - 25.03.2026\CrimeCodeDescription.csv'&#xA;WITH (FIRSTROW=2, FIELDTERMINATOR=',', ROWTERMINATOR='\n', CODEPAGE='65001');&#xA;&#xA;BULK INSERT STG_PremiseCode&#xA;FROM 'C:\Users\Yahya\Desktop\SLIIT\Year 3\Sem 2\DWBI\Assignment 1 - 25.03.2026\PremiseCodeDescription.csv'&#xA;WITH (FIRSTROW=2, FIELDTERMINATOR=',', ROWTERMINATOR='\n', CODEPAGE='65001');&#xA;&#xA;BULK INSERT STG_WeaponCode&#xA;FROM 'C:\Users\Yahya\Desktop\SLIIT\Year 3\Sem 2\DWBI\Assignment 1 - 25.03.2026\WeaponCodeDescription.csv'&#xA;WITH (FIRSTROW=2, FIELDTERMINATOR=',', ROWTERMINATOR='\n', CODEPAGE='65001');&#xA;&#xA;BULK INSERT STG_AreaCode&#xA;FROM 'C:\Users\Yahya\Desktop\SLIIT\Year 3\Sem 2\DWBI\Assignment 1 - 25.03.2026\AreaCodeDescription.csv'&#xA;WITH (FIRSTROW=2, FIELDTERMINATOR=',', ROWTERMINATOR='\n', CODEPAGE='65001');&#xA;&#xA;-- Load DIM_CRIME&#xA;INSERT INTO DIM_CRIME &#xA;(CrimeCode, CrimeDescription, CrimeCategory, CrimeSeverity, IsViolent, IsPropertyCrime)&#xA;SELECT &#xA;    TRY_CAST(CrimeCode AS INT),&#xA;    CrimeCodeDesc,&#xA;    CASE WHEN TRY_CAST(CrimeCode AS INT) &lt;= 299 THEN 'Violent'&#xA;         WHEN TRY_CAST(CrimeCode AS INT) &lt;= 599 THEN 'Property'&#xA;         ELSE 'Other' END,&#xA;    CASE WHEN TRY_CAST(CrimeCode AS INT) &lt;= 299 THEN 'Part 1'&#xA;         ELSE 'Part 2' END,&#xA;    CASE WHEN TRY_CAST(CrimeCode AS INT) &lt;= 299 THEN 'True' ELSE 'False' END,&#xA;    CASE WHEN TRY_CAST(CrimeCode AS INT) BETWEEN 300 AND 599 THEN 'True' ELSE 'False' END&#xA;FROM STG_CrimeCode&#xA;WHERE TRY_CAST(CrimeCode AS INT) IS NOT NULL;&#xA;&#xA;-- Load DIM_PREMISE&#xA;INSERT INTO DIM_PREMISE (PremiseCode, PremiseDescription, PremiseCategory)&#xA;SELECT &#xA;    TRY_CAST(PremiseCode AS INT),&#xA;    PremiseDesc,&#xA;    CASE WHEN PremiseDesc LIKE '%HOUSE%' OR PremiseDesc LIKE '%APART%' THEN 'Residential'&#xA;         WHEN PremiseDesc LIKE '%STORE%' OR PremiseDesc LIKE '%SHOP%' THEN 'Commercial'&#xA;         WHEN PremiseDesc LIKE '%STREET%' OR PremiseDesc LIKE '%SIDEWALK%' THEN 'Public'&#xA;         WHEN PremiseDesc LIKE '%VEHICLE%' OR PremiseDesc LIKE '%CAR%' THEN 'Vehicle'&#xA;         ELSE 'Other' END&#xA;FROM STG_PremiseCode&#xA;WHERE TRY_CAST(PremiseCode AS INT) IS NOT NULL;&#xA;&#xA;-- Load DIM_WEAPON&#xA;INSERT INTO DIM_WEAPON (WeaponCode, WeaponDescription, WeaponCategory)&#xA;SELECT &#xA;    TRY_CAST(WeaponCode AS INT),&#xA;    WeaponDesc,&#xA;    CASE WHEN TRY_CAST(WeaponCode AS INT) = 0 THEN 'Unknown'&#xA;         WHEN TRY_CAST(WeaponCode AS INT) BETWEEN 101 AND 109 THEN 'Firearm'&#xA;         WHEN TRY_CAST(WeaponCode AS INT) BETWEEN 110 AND 115 THEN 'Knife'&#xA;         ELSE 'Physical' END&#xA;FROM STG_WeaponCode&#xA;WHERE TRY_CAST(WeaponCode AS INT) IS NOT NULL;&#xA;&#xA;-- Load DIM_AREA&#xA;INSERT INTO DIM_AREA &#xA;(AreaCode, AreaName, Region, Division, EffectiveDate, ExpiryDate, IsCurrent)&#xA;SELECT &#xA;    TRY_CAST(AreaCode AS INT),&#xA;    AreaName,&#xA;    CASE WHEN TRY_CAST(AreaCode AS INT) IN (1,2,6,7) THEN 'Central'&#xA;         WHEN TRY_CAST(AreaCode AS INT) IN (3,5,12,13,18) THEN 'South'&#xA;         WHEN TRY_CAST(AreaCode AS INT) IN (8,14,20) THEN 'West'&#xA;         WHEN TRY_CAST(AreaCode AS INT) IN (9,10,15,16,17,19,21) THEN 'Valley'&#xA;         ELSE 'East' END,&#xA;    'Patrol Division',&#xA;    '2018-01-01',&#xA;    NULL,&#xA;    1&#xA;FROM STG_AreaCode&#xA;WHERE TRY_CAST(AreaCode AS INT) IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DIM_STATUS"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{199D0010-EE42-4ED9-85EB-89159A240A92}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DIM_STATUS"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C4C06672-7538-4198-9C52-3251DFA1BC2C}"
          SQLTask:SqlStatementSource="-- Clear and reload DIM_STATUS cleanly&#xA;DELETE FROM DIM_STATUS;&#xA;DBCC CHECKIDENT ('DIM_STATUS', RESEED, 0);&#xA;&#xA;INSERT INTO DIM_STATUS (StatusCode, StatusDescription, StatusCategory) VALUES&#xA;('AA',  'Adult Arrest',  'Arrest'),&#xA;('IC',  'Invest Cont',   'Investigation'),&#xA;('AO',  'Adult Other',   'Other'),&#xA;('JA',  'Juv Arrest',    'Arrest'),&#xA;('JO',  'Juv Other',     'Other'),&#xA;('CC',  'UNK',           'Unknown'),&#xA;('13',  'Juv Other',     'Juvenile'),&#xA;('14',  'Other',         'Other');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DIM_VICTIM"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{2886FF1D-BF4F-49CF-8BA4-40CE98777335}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DIM_VICTIM"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C4C06672-7538-4198-9C52-3251DFA1BC2C}"
          SQLTask:SqlStatementSource="DELETE FROM DIM_VICTIM;&#xA;DBCC CHECKIDENT ('DIM_VICTIM', RESEED, 0);&#xA;&#xA;INSERT INTO DIM_VICTIM&#xA;(VictimNK, VictimAge, AgeGroup, VictimGender, GenderDescription,&#xA; VictimDescent, DescentDescription, EffectiveDate, ExpiryDate, IsCurrent)&#xA;SELECT &#xA;    DR_NO,&#xA;    ISNULL(Victim_Age, 0),&#xA;    CASE WHEN ISNULL(Victim_Age,0) = 0 THEN 'Unknown'&#xA;         WHEN Victim_Age &lt;= 12 THEN 'Child'&#xA;         WHEN Victim_Age &lt;= 17 THEN 'Teen'&#xA;         WHEN Victim_Age &lt;= 59 THEN 'Adult'&#xA;         ELSE 'Senior' END,&#xA;    ISNULL(Victim_Gender, 'X'),&#xA;    CASE WHEN Victim_Gender = 'M' THEN 'Male'&#xA;         WHEN Victim_Gender = 'F' THEN 'Female'&#xA;         ELSE 'Unknown' END,&#xA;    Victim_OriginalCountry,&#xA;    CASE WHEN Victim_OriginalCountry = 'H' THEN 'Hispanic'&#xA;         WHEN Victim_OriginalCountry = 'W' THEN 'White'&#xA;         WHEN Victim_OriginalCountry = 'B' THEN 'Black'&#xA;         WHEN Victim_OriginalCountry = 'A' THEN 'Asian'&#xA;         WHEN Victim_OriginalCountry = 'O' THEN 'Other'&#xA;         ELSE 'Unknown' END,&#xA;    CAST(GETDATE() AS DATE),&#xA;    NULL,&#xA;    1&#xA;FROM STG_VictimData&#xA;WHERE DR_NO IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load FACT_CRIME_INCIDENT"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{AC02E49B-4B53-4668-AB81-A693F91EA077}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FACT_CRIME_INCIDENT"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C4C06672-7538-4198-9C52-3251DFA1BC2C}"
          SQLTask:SqlStatementSource="-- First insert a default unknown victim if not exists&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_VICTIM WHERE VictimSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_VICTIM ON;&#xA;    INSERT INTO DIM_VICTIM &#xA;    (VictimSK, VictimNK, VictimAge, AgeGroup, VictimGender, &#xA;     GenderDescription, VictimDescent, DescentDescription, &#xA;     EffectiveDate, ExpiryDate, IsCurrent)&#xA;    VALUES (1, 0, 0, 'Unknown', 'X', 'Unknown', NULL, 'Unknown', &#xA;            '2018-01-01', NULL, 1);&#xA;    SET IDENTITY_INSERT DIM_VICTIM OFF;&#xA;END&#xA;&#xA;-- Insert default unknown rows for other dimensions if needed&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_AREA WHERE AreaSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_AREA ON;&#xA;    INSERT INTO DIM_AREA &#xA;    (AreaSK, AreaCode, AreaName, Region, Division, EffectiveDate, ExpiryDate, IsCurrent)&#xA;    VALUES (1, 0, 'Unknown', 'Unknown', 'Unknown', '2018-01-01', NULL, 1);&#xA;    SET IDENTITY_INSERT DIM_AREA OFF;&#xA;END&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_CRIME WHERE CrimeSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_CRIME ON;&#xA;    INSERT INTO DIM_CRIME &#xA;    (CrimeSK, CrimeCode, CrimeDescription, CrimeCategory, CrimeSeverity, IsViolent, IsPropertyCrime)&#xA;    VALUES (1, 0, 'Unknown', 'Other', 'Part 2', 'False', 'False');&#xA;    SET IDENTITY_INSERT DIM_CRIME OFF;&#xA;END&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_PREMISE WHERE PremiseSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_PREMISE ON;&#xA;    INSERT INTO DIM_PREMISE (PremiseSK, PremiseCode, PremiseDescription, PremiseCategory)&#xA;    VALUES (1, 0, 'Unknown', 'Other');&#xA;    SET IDENTITY_INSERT DIM_PREMISE OFF;&#xA;END&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_WEAPON WHERE WeaponSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_WEAPON ON;&#xA;    INSERT INTO DIM_WEAPON (WeaponSK, WeaponCode, WeaponDescription, WeaponCategory)&#xA;    VALUES (1, 0, 'Unknown', 'Unknown');&#xA;    SET IDENTITY_INSERT DIM_WEAPON OFF;&#xA;END&#xA;&#xA;IF NOT EXISTS (SELECT 1 FROM DIM_STATUS WHERE StatusSK = 1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT DIM_STATUS ON;&#xA;    INSERT INTO DIM_STATUS (StatusSK, StatusCode, StatusDescription, StatusCategory)&#xA;    VALUES (1, 'XX', 'Unknown', 'Unknown');&#xA;    SET IDENTITY_INSERT DIM_STATUS OFF;&#xA;END&#xA;&#xA;-- Now insert fact rows&#xA;INSERT INTO FACT_CRIME_INCIDENT&#xA;(DR_NO, DateOccurredKey, DateReportedKey, TimeOccurredKey,&#xA; AreaSK, CrimeSK, PremiseSK, WeaponSK, StatusSK, VictimSK,&#xA; ReportDistrictNo, Part_1_2, IncidentCount, DaysToReport,&#xA; VictimAge, Latitude, Longitude)&#xA;SELECT &#xA;    ci.DR_NO,&#xA;    CAST(FORMAT(CAST(ci.Date_Occurred AS DATE), 'yyyyMMdd') AS INT),&#xA;    CAST(FORMAT(CAST(ci.Date_Reported AS DATE), 'yyyyMMdd') AS INT),&#xA;    ISNULL(TRY_CAST(ci.Time_Occurred AS INT), 0),&#xA;    ISNULL((SELECT TOP 1 AreaSK FROM DIM_AREA &#xA;            WHERE AreaCode = ci.Area_Code AND IsCurrent = 1), 1),&#xA;    ISNULL((SELECT TOP 1 CrimeSK FROM DIM_CRIME &#xA;            WHERE CrimeCode = ci.Crime_Code), 1),&#xA;    ISNULL((SELECT TOP 1 PremiseSK FROM DIM_PREMISE &#xA;            WHERE PremiseCode = ci.Premise_Code), 1),&#xA;    ISNULL((SELECT TOP 1 WeaponSK FROM DIM_WEAPON &#xA;            WHERE WeaponCode = ISNULL(ci.Weapon_Code, 0)), 1),&#xA;    ISNULL((SELECT TOP 1 StatusSK FROM DIM_STATUS &#xA;            WHERE RTRIM(LTRIM(StatusCode)) = RTRIM(LTRIM(ci.Status_Code))), 1),&#xA;    ISNULL((SELECT TOP 1 VictimSK FROM DIM_VICTIM &#xA;            WHERE VictimNK = ci.DR_NO AND IsCurrent = 1), 1),&#xA;    ci.Rpt_District_No,&#xA;    ci.Part_1_2,&#xA;    1,&#xA;    ISNULL(DATEDIFF(DAY,&#xA;        TRY_CAST(ci.Date_Occurred AS DATE),&#xA;        TRY_CAST(ci.Date_Reported AS DATE)), 0),&#xA;    ISNULL(vd.Victim_Age, 0),&#xA;    ci.Latitude,&#xA;    ci.Longitude&#xA;FROM STG_CrimeIncidents ci&#xA;LEFT JOIN STG_VictimData vd ON ci.DR_NO = vd.DR_NO&#xA;WHERE ci.DR_NO IS NOT NULL&#xA;AND TRY_CAST(ci.Date_Occurred AS DATE) IS NOT NULL&#xA;AND TRY_CAST(ci.Date_Reported AS DATE) IS NOT NULL&#xA;AND NOT EXISTS (&#xA;    SELECT 1 FROM FACT_CRIME_INCIDENT f &#xA;    WHERE f.DR_NO = ci.DR_NO&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
